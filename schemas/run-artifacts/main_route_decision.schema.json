{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "main_route_decision",
  "type": "object",
  "required": ["session_id", "producer_agent", "decision_point_id", "assessor_artifact", "route", "reason", "based_on_artifacts"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "decision_point_id": {"type": "string"},
    "assessor_artifact": {"type": "string"},
    "route": {"enum": ["coder_rework", "planner_rework", "collect_more_evidence", "rerun_board_validation", "escalate_to_user", "close_as_environment_issue", "proceed_to_closure"]},
    "reason": {"type": "string", "minLength": 1},
    "based_on_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
