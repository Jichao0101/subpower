{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "route_history",
  "type": "object",
  "required": ["session_id", "producer_agent", "routes"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["round", "decision_point_id", "assessor_artifact", "route", "reason", "timestamp"],
        "additionalProperties": false,
        "properties": {
          "round": {"type": "integer", "minimum": 1},
          "decision_point_id": {"type": "string", "minLength": 1},
          "assessor_artifact": {"type": "string", "minLength": 1},
          "route": {"enum": ["coder_rework", "planner_rework", "collect_more_evidence", "rerun_board_validation", "escalate_to_user", "close_as_environment_issue", "proceed_to_closure", "stop", "functional_review", "writeback_declined"]},
          "reason": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
