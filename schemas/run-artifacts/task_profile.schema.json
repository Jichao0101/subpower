{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "task_profile",
  "type": "object",
  "required": ["session_id", "producer_agent", "primary_type", "task_goal"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "subpower_invoked": {"type": "boolean"},
    "execution_mode": {"enum": ["subpower", "standard"]},
    "primary_type": {"enum": ["incident_investigation", "bug_fix", "board_validation", "functional_review", "knowledge_writeback"]},
    "task_goal": {"type": "string", "minLength": 1},
    "task_modifiers": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
