{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "handoff_packet",
  "type": "object",
  "required": ["session_id", "from_agent", "to_agent", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "from_agent": {"type": "string", "minLength": 1},
    "to_agent": {"type": "string", "minLength": 1},
    "artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
