{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "workflow_plan",
  "type": "object",
  "required": ["session_id", "producer_agent", "workflow_id", "planned_steps"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string"},
    "producer_agent": {"type": "string"},
    "workflow_id": {"enum": ["incident_investigation", "bug_fix", "board_validation", "functional_review", "knowledge_writeback"]},
    "planned_steps": {"type": "array", "items": {"type": "string"}}
  }
}
