{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "board_failure_review",
  "type": "object",
  "required": ["session_id", "producer_agent", "failure_class", "recommended_next", "confidence", "blocking_evidence", "rationale"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string"},
    "producer_agent": {"type": "string"},
    "failure_class": {"enum": ["implementation_defect", "plan_mismatch", "requirement_ambiguity", "insufficient_evidence", "environment_issue", "test_setup_issue", "regression_risk", "unknown"]},
    "recommended_next": {"enum": ["coder_rework", "planner_rework", "collect_more_evidence", "rerun_board_validation", "escalate_to_user", "close_as_environment_issue"]},
    "confidence": {"type": "number"},
    "blocking_evidence": {"type": "array", "items": {"type": "string"}},
    "rationale": {"type": "array", "items": {"type": "string"}}
  }
}
