{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "board_target",
  "type": "object",
  "required": ["session_id", "producer_agent", "board_target_id", "run_commands", "collect_paths"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "board_target_id": {"type": "string"},
    "run_commands": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "collect_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
