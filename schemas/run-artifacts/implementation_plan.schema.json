{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "implementation_plan",
  "type": "object",
  "required": ["session_id", "producer_agent", "repo_scope", "verification_plan"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "repo_scope": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "verification_plan": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
