{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "writeback_declined",
  "type": "object",
  "required": ["session_id", "producer_agent", "candidate_artifact", "reason", "blockers", "evidence_refs"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "candidate_artifact": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "blockers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
