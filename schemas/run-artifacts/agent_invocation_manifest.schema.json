{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "agent_invocation_manifest",
  "type": "object",
  "required": ["session_id", "producer_agent", "invocations"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["invocation_id", "agent_id", "role_id"],
        "additionalProperties": false,
        "properties": {
          "invocation_id": {"type": "string", "minLength": 1},
          "agent_id": {"type": "string", "minLength": 1},
          "role_id": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
