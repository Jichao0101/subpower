{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "code_change_manifest",
  "type": "object",
  "required": ["session_id", "producer_agent", "files_changed", "verification_results"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "files_changed": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "verification_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "additionalProperties": false,
        "properties": {
          "command": {"type": "string"},
          "status": {"enum": ["passed", "failed", "blocked"]}
        }
      }
    }
  }
}
