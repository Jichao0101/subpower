{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "incident_report",
  "type": "object",
  "required": ["session_id", "producer_agent", "observed_symptom", "evidence_refs", "summary"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "observed_symptom": {"type": "string", "minLength": 1},
    "evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "summary": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
