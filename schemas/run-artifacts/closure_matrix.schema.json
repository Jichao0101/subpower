{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "closure_matrix",
  "type": "object",
  "required": ["session_id", "producer_agent", "close_allowed", "review_status", "evidence_status", "repo_state", "board_state", "knowledge_state", "blockers"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "close_allowed": {"type": "boolean"},
    "review_status": {"enum": ["approved", "changes_requested", "blocked", "not_required"]},
    "evidence_status": {"enum": ["sufficient", "insufficient", "blocked"]},
    "repo_state": {"enum": ["untouched", "planned", "changed", "locally_verified", "reviewed", "rework_required", "merged_ready", "blocked"]},
    "board_state": {"enum": ["not_required", "target_pending", "target_bound", "executed", "evidence_collected", "failed", "passed", "blocked"]},
    "knowledge_state": {"enum": ["context_pending", "context_ready", "writeback_pending", "writeback_done", "synced", "blocked"]},
    "required_artifacts": {"type": "array", "items": {"type": "string"}},
    "completed_as_subagent_first_execution": {"type": "boolean"},
    "completed_by_subpower": {"type": "boolean"},
    "complete_subpower_execution": {"type": "boolean"},
    "completed_under_subpower_contracts_with_host_only_fallback": {"type": "boolean"},
    "degraded": {"type": "boolean"},
    "independence_evidence_status": {"enum": ["complete", "degraded", "insufficient_independence_evidence", "not_required"]},
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
