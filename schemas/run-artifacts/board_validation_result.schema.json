{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "board_validation_result",
  "type": "object",
  "required": ["session_id", "producer_agent", "status", "evidence_refs"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed", "blocked"]},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
