{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "board_session",
  "type": "object",
  "required": ["session_id", "producer_agent", "board", "scenario", "status"],
  "additionalProperties": false,
  "properties": {
    "session_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"},
    "producer_agent": {"type": "string", "minLength": 1},
    "board": {"type": "string"},
    "scenario": {"type": "string"},
    "status": {"enum": ["started", "completed", "failed", "blocked"]}
  }
}
